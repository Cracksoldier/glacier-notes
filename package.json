{
  "name": "glacier-notes",
  "version": "0.1.0",
  "description": "Glacier Notes — offline note-taking app (Electron + Angular)",
  "author": {
    "name": "Glacier Notes contributors",
    "email": "Cracksoldier@users.noreply.github.com"
  },
  "homepage": "https://github.com/Cracksoldier/glacier-notes",
  "desktopName": "com.glacier.notes",
  "main": "dist-electron/main.js",
  "scripts": {
    "ng": "ng",
    "start": "concurrently -k -n angular,electron -c blue,cyan \"ng serve\" \"npm run electron:dev\"",
    "electron:dev": "wait-on tcp:localhost:4200 && tsc -p electron && GLACIER_DEV=1 electron .",
    "build": "ng build && tsc -p electron",
    "electron:prod": "npm run build && electron .",
    "package": "npm run build && electron-builder --publish never",
    "package:dir": "npm run build && electron-builder --dir --publish never",
    "package:linux": "npm run build && electron-builder --linux --x64 --publish never",
    "package:win": "npm run build && electron-builder --win --x64 --publish never",
    "package:mac": "npm run build && electron-builder --mac --x64 --publish never",
    "verify:offline": "node scripts/verify-offline.mjs",
    "smoke:packaged": "node scripts/smoke-packaged.mjs",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@fortawesome/fontawesome-free": "^7.3.1",
    "dompurify": "^3.4.12",
    "marked": "^18.0.6",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.7",
    "@angular/cli": "^22.0.7",
    "@angular/compiler-cli": "^22.0.0",
    "@biomejs/biome": "2.5.4",
    "concurrently": "^10.0.3",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "jsdom": "^28.0.0",
    "typescript": "~6.0.2",
    "vitest": "^4.0.8",
    "wait-on": "^9.0.10"
  }
}
